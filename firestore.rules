rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
        && data.keys().size() == 5
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 256
        && data.photoURL is string && data.photoURL.size() <= 2048
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    function isValidAnalysisLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'fileName', 'language', 'code', 'bugHunter', 'complexity', 'doc'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.timestamp is string && data.timestamp.size() <= 128
        && data.fileName is string && data.fileName.size() <= 256
        && data.language is string && data.language.size() <= 64
        && data.code is string && data.code.size() <= 500000
        && data.bugHunter is map
        && data.complexity is map
        && data.doc is map;
    }

    // User profiles
    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Code analysis logs (subcollection)
    match /users/{userId}/analysis_logs/{logId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidId(logId) && isValidAnalysisLog(incoming());
    }
  }
}
